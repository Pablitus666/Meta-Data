# ============================================================
# MetaData - .gitignore
# ============================================================

# ============================================================
# 🐍 Python / Entorno
# ============================================================

__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

venv/
env/
.venv/
ENV/

# ============================================================
# 🏗️ Build / Compilación
# ============================================================

build/
dist/
*.spec
*.manifest

# PyInstaller temporales
*.toc
*.log

# ============================================================
# 📦 Distribución / Instaladores (NO subir)
# ============================================================

*.exe
*.msi
*.msix
*.iss
*.zip
*.rar
*.7z

installer/
release/
releases/

# ============================================================
# 🔐 Seguridad - Certificados y Firma Digital
# ============================================================

*.pfx
*.cer
*.p12
*.p7b
*.key
*.pem
*.crt

# Archivos específicos de firma
firmar_app.ps1
Walter_Pablo_Tellez_Ayala_CodeSigning.*

# ============================================================
# 🖼️ Archivos de Diseño
# ============================================================

*.psd
*.ai
*.xcf

# ============================================================
# 📝 Logs y Persistencia
# ============================================================

*.log
*.tmp

# ============================================================
# 🧠 IDEs / Editores
# ============================================================

.vscode/
.idea/
*.swp
*.swo

# ============================================================
# 💻 Sistema Operativo
# ============================================================

Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store